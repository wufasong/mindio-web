FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
ARG SERVER_VERSION=1.0.0
RUN apk add --no-cache wget && \
    wget -O mindio-server.jar \
    "https://github.com/wufasong/mindio-web/releases/download/v${SERVER_VERSION}/mindio-server-${SERVER_VERSION}.jar"
EXPOSE 8080
ENV JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"
CMD ["sh", "-c", "java $JAVA_OPTS -jar mindio-server.jar --spring.profiles.active=prod"]
